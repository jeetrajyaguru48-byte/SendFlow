# Google OAuth2 Configuration
# Get these from Google Cloud Console: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# Application Settings
SECRET_KEY=your_super_secret_key_change_in_production
SCHEDULER_SECRET=your_scheduler_secret_change_in_production
DATABASE_URL=sqlite:///./database/email_automation.db
FRONTEND_URL=http://localhost:8081
CORS_ORIGINS=http://localhost:8081,http://127.0.0.1:8081

# Email Settings
DEV_MODE=false
TEST_EMAIL_INBOX=/tmp/sendflow_emails
MAX_EMAILS_PER_DAY=30
MIN_DELAY_MINUTES=2
MAX_DELAY_MINUTES=7

# Base URL for tracking (change if deploying)
BASE_URL=http://localhost:8000
EMAIL_TRACKING_ENABLED=true
DEFAULT_TIMEZONE=Asia/Kolkata

# Production examples
# DATABASE_URL=postgresql://neondb_owner:password@ep-example.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
# FRONTEND_URL=https://your-frontend.vercel.app
# CORS_ORIGINS=https://your-frontend.vercel.app
# BASE_URL=https://your-backend.vercel.app
# GOOGLE_REDIRECT_URI=https://your-backend.vercel.app/auth/callback
